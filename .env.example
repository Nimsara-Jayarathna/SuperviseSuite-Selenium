# SuperviseSuite Selenium test environment example
# Usage:
#   cp .env.example .env
#   set -a; source .env; set +a
#   mvn test

# Browser policy
browser=chrome
allowed.browsers=chrome,firefox,safari
run.mode=single
run.browsers=chrome,firefox,safari

# Frontend base URL
base.url=http://localhost:5173

# Driver/Web timings (seconds)
implicit.wait.seconds=5
page.load.timeout.seconds=30
script.timeout.seconds=30
modal.wait.seconds=10

# Interaction speed profile:
#   fast   -> instant typing/click flow (step=0,   char=0)
#   normal -> visible but practical flow   (step=700, char=60)
#   slow   -> very clear demo flow         (step=1200,char=80)
speed.profile=normal

# Optional direct overrides (milliseconds)
# Keep these commented to use speed.profile mapping above.
# Uncomment only if you need custom per-run timing.
# step.delay.ms=700
# char.delay.ms=60

# Story key fallback (used if @UserStory is not present)
test.story.key=US-201

# Retry/flakiness control
retry.max=0

# Enforce deterministic display-name format
naming.validation.enabled=true
test.name.pattern=^TC-\d+.*$

# Preflight checks for required services
preflight.enabled=true
preflight.timeout.seconds=5
backend.base.url=http://localhost:8080

# Optional backend-side role assertion in tests
backend.role.assertion.enabled=false

# Proof report output (committable evidence, outside target/)
proofs.enabled=true
proofs.dir=proofs
# Optional fixed run id (default: timestamp yyyyMMdd-HHmmss)
# proofs.run.id=20260405-082133
