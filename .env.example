# SuperviseSuite Selenium test environment example
# Usage:
#   cp .env.example .env
#   set -a; source .env; set +a
#   mvn test

# Browser policy
browser=chrome
allowed.browsers=chrome,firefox,safari

# Frontend base URL
base.url=http://localhost:5173

# Driver/Web timings (seconds)
implicit.wait.seconds=5
page.load.timeout.seconds=30
script.timeout.seconds=30
modal.wait.seconds=10

# Interaction speed profile: fast | normal | slow
speed.profile=normal

# Optional direct overrides (milliseconds)
# These override speed.profile defaults if set.
step.delay.ms=700
char.delay.ms=60

# Story key fallback (used if @UserStory is not present)
test.story.key=US-201
